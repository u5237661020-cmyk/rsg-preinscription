rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function hasRequiredPublicFields() {
      return request.resource.data.keys().hasAll(['id', 'nom', 'prenom', 'saison'])
        && request.resource.data.id is string
        && request.resource.data.id.size() < 100
        && request.resource.data.nom is string
        && request.resource.data.nom.size() < 100
        && request.resource.data.prenom is string
        && request.resource.data.prenom.size() < 100
        && request.resource.data.saison is string
        && request.resource.data.saison.size() < 30;
    }

    function isSafePublicCreate() {
      return hasRequiredPublicFields()
        && request.resource.data.statut == 'attente'
        && (!request.resource.data.keys().hasAny(['datePaiement']) || request.resource.data.datePaiement == null)
        && (!request.resource.data.keys().hasAny(['dateValidation']) || request.resource.data.dateValidation == null)
        && (!request.resource.data.keys().hasAny(['emailAttestationEnvoye']) || request.resource.data.emailAttestationEnvoye == false)
        && !request.resource.data.keys().hasAny([
          'emailAttestationEnvoyeLe',
          'emailAttestationDernierDestinataire',
          'emailAttestationMessageId',
          'emailAttestationStatus',
          'emailAttestationErreur',
          'emailAttestationSource',
          'footclubsStatut',
          'footclubsCommentaire'
        ]);
    }

    match /saisons/{saison}/preinscriptions/{id} {
      allow create: if isSafePublicCreate();
      allow get, list, update, delete: if isAdmin();
    }

    match /saisons/{saison}/config/{document=**} {
      allow read, write: if isAdmin();
    }

    match /config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /security/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
